{
  "name": "work-experience",
  "private": true,
  "scripts": {
    "build": "nuxt build && node scripts/postbuild.js",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "nuxt start",
    "postinstall": "nuxt prepare",
    "codegen": "yarn openapi-ts",
    "lint": "eslint $(git diff --name-only --cached --relative | grep -E '\\.(js|vue|ts)$' | xargs)",
    "lint:full": "eslint .",
    "lint:commit": "eslint",
    "typecheck": "vue-tsc --noEmit 2>&1 | grep -v 'node_modules' || echo 'Type checking complete!'",
    "generate-logos": "node scripts/generate-logo-grid.js --include 'alnwick-castle,yorkshire-sculpture-park,storybook,beatcovidne,taxigoat,boiler-plan,visit-northumberland,glasgow-retina,research-portal,nightingale-design-research'"
  },
  "lint-staged": {
    "*.{js,vue,ts}": "yarn lint:commit"
  },
  "resolutions": {
    "vue": "3.5.30"
  },
  "dependencies": {
    "@auth0/auth0-vue": "^2.5.0",
    "@floating-ui/dom": "^1.7.6",
    "@hey-api/client-axios": "^0.9.1",
    "@pinia/nuxt": "^0.11.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tiptap/core": "^3.20.2",
    "@tiptap/pm": "^3.20.2",
    "@tiptap/starter-kit": "^3.20.2",
    "@tiptap/vue-3": "^3.20.2",
    "@types/node": "^25.5.0",
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "axios": "^1.13.6",
    "daisyui": "^5.5.19",
    "date-fns": "^4.1.0",
    "lodash-es": "^4.17.23",
    "marked": "^17.0.4",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vue-eslint-parser": "^10.4.0",
    "vue3-colorpicker": "^2.3.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.94.1",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/ic": "^1.2.4",
    "@iconify-json/material-symbols": "^1.2.62",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.74",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/sitemap": "^7.6.0",
    "@pinia-plugin-persistedstate/nuxt": "^1.2.1",
    "@types/lodash-es": "^4.17.12",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nuxt": "^4.4.2",
    "nuxt-umami": "^3.2.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "vue-tsc": "^3.2.5"
  }
}
