{
  // https://nuxt.com/docs/guide/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "~/*": [
        "./*"
      ],
      "@/*": [
        "./*"
      ]
    },
    // Explicitly skip checking d.ts files in node_modules
    "skipDefaultLibCheck": true
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "app/**/*.vue",
    "server/**/*.ts",
    "api/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".nuxt",
    ".output",
    "dist",
    // Explicitly exclude problematic .mts files
    "**/*.mts",
    "**/node_modules/**"
  ]
}